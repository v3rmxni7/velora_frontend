# velora_frontend env. These are NEXT_PUBLIC_* → INLINED AT BUILD TIME (Vercel): set them in the
# Vercel project BEFORE the first build; changing them requires a rebuild.

# Same Supabase project as velora_backend. The anon key is browser-safe by design (RLS authorizes
# every row); the service-role key must NEVER appear in this repo. Missing/invalid here → the auth
# proxy gate throws and every page errors.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The velora_backend API origin. Local dev: pnpm dev in velora_backend → http://localhost:8080.
# In production this MUST be the deployed Railway origin, or the bundle ships localhost (broken API
# calls + a localhost pixel snippet shown to customers).
NEXT_PUBLIC_API_URL=http://localhost:8080
